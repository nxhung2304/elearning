<%= simple_form_for course_category, html: { autocomplete: "off" } do |f| %>
  <% course_category.class.visible_columns.each do |col| %>
    <% if course_category.class.defined_enums.key?(col) %>
      <%= f.input col.to_sym, as: :select, collection: course_category.class.defined_enums[col].keys, include_blank: false, wrapper: :select,
            input_html: { data: { controller: "select" } } %>
    <% else %>
      <%= f.input col.to_sym %>
    <% end %>
  <% end %>

  <%= f.input :parent_id,
              as: :select,
              collection: @parent_categories,
              include_blank: true,
              input_html: { data: { controller: "select" } } %>

  <div class="mt-6 flex items-center gap-3">
    <%= f.button :submit,
          t("helpers.submit.#{course_category.persisted? ? :update : :create}", model: CourseCategory.model_name.human),
          class: "rounded-lg #{course_category.persisted? ? "bg-slate-900 hover:bg-slate-700" : "bg-emerald-600 hover:bg-emerald-700"} px-4 py-2 text-sm font-medium text-white" %>
    <%= link_to t("helpers.links.cancel", default: "Cancel"),
          course_categories_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
