<% add_breadcrumb CourseCategory.model_name.human, course_categories_path %>
<% add_breadcrumb @course_category.name, course_category_path(@course_category) %>
<% add_breadcrumb t('.title') %>

<section class="mx-auto max-w-2xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">
      <%= t("helpers.submit.update", model: CourseCategory.model_name.human, default: "Edit CourseCategory") %>
    </h1>
    <%= button_to t("helpers.links.delete", default: "Delete"),
          course_category_path(@course_category),
          method: :delete,
          data: { turbo_confirm: t("helpers.confirm", default: "Are you sure?") },
          class: "rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-100" %>
  </div>

  <%= render "form", course_category: @course_category %>
</section>

