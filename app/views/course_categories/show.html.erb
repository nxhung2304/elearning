<% add_breadcrumb CourseCategory.model_name.human, course_categories_path %>
<% add_breadcrumb @course_category.name %>

<section class="mx-auto max-w-3xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900"><%= CourseCategory.model_name.human %></h1>
    <%= link_to t("helpers.links.back", default: "Back"),
          course_categories_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>

  <dl class="divide-y divide-slate-200 rounded-xl border border-slate-200">
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= CourseCategory.human_attribute_name(:name) %></dt>
      <dd class="text-slate-900"><%= @course_category.name %></dd>
    </div>

    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= CourseCategory.human_attribute_name(:parent) %></dt>
      <dd class="text-slate-900">
        <% if @course_category.parent.present? %>
          <%= link_to @course_category.parent.name, course_category_path(@course_category.parent), class: "text-blue-600 hover:underline" %>
        <% else %>
          <span class="text-slate-400">—</span>
        <% end %>
      </dd>
    </div>

    <% if @course_category.children.kept.any? %>
      <div class="flex px-4 py-3 gap-4">
        <dt class="w-1/3 font-medium text-slate-600"><%= CourseCategory.model_name.human.pluralize %></dt>
        <dd class="flex flex-wrap gap-2">
          <% @course_category.children.kept.each do |child| %>
            <%= link_to child.name, course_category_path(child), class: "rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700 hover:bg-slate-200" %>
          <% end %>
        </dd>
      </div>
    <% end %>

    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= CourseCategory.human_attribute_name(:created_at) %></dt>
      <dd class="text-slate-500 text-sm"><%= @course_category.created_at&.strftime("%Y-%m-%d %H:%M") %></dd>
    </div>
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= CourseCategory.human_attribute_name(:updated_at) %></dt>
      <dd class="text-slate-500 text-sm"><%= @course_category.updated_at&.strftime("%Y-%m-%d %H:%M") %></dd>
    </div>
  </dl>
</section>
