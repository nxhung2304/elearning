<% add_breadcrumb "Users", users_path %>
<% add_breadcrumb @user.email %>

<section class="mx-auto max-w-3xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900"><%= User.model_name.human %></h1>
    <%= link_to t("helpers.links.back", default: "Back"),
          users_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>

  <dl class="divide-y divide-slate-200 rounded-xl border border-slate-200">
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= User.human_attribute_name(:email) %></dt>
      <dd class="text-slate-900"><%= @user.email %></dd>
    </div>
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= User.human_attribute_name(:name) %></dt>
      <dd class="text-slate-900"><%= @user.name %></dd>
    </div>
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= User.human_attribute_name(:status) %></dt>
      <dd class="text-slate-900"><%= render "shared/status_badge", status: @user.status %></dd>
    </div>
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= User.human_attribute_name(:created_at) %></dt>
      <dd class="text-slate-500 text-sm"><%= @user.created_at&.strftime("%Y-%m-%d %H:%M") %></dd>
    </div>
    <div class="flex px-4 py-3 gap-4">
      <dt class="w-1/3 font-medium text-slate-600"><%= User.human_attribute_name(:updated_at) %></dt>
      <dd class="text-slate-500 text-sm"><%= @user.updated_at&.strftime("%Y-%m-%d %H:%M") %></dd>
    </div>
  </dl>
</section>
