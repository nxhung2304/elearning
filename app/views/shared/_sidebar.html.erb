<aside data-controller="sidebar" class="w-60 shrink-0 bg-white border-r border-slate-200 flex flex-col transition-all duration-200 overflow-hidden">
  <div data-sidebar-target="header" class="px-3 py-5 border-b border-slate-200 flex items-center justify-between">
    <%= link_to root_path, data: { "sidebar-target": "logo" }, class: "flex items-center gap-2 min-w-0" do %>
      <svg class="h-5 w-5 shrink-0 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <span data-sidebar-target="label" class="text-base font-semibold tracking-tight truncate"><%= t('layouts.application.title') %></span>
    <% end %>
    <button data-action="click->sidebar#toggle" class="shrink-0 rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600">
      <svg data-sidebar-target="chevron" class="h-4 w-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
  </div>

  <nav class="flex-1 px-3 py-4 space-y-1">
    <%= link_to root_path, data: { "sidebar-target": "link" }, class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 #{'bg-slate-100' if current_page?(root_path)}" do %>
      <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      <span data-sidebar-target="label"><%= t('.dashboard') %></span>
    <% end %>

    <%= link_to users_path, data: { "sidebar-target": "link" }, class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 #{'bg-slate-100' if request.path.start_with?('/users')}" do %>
      <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span data-sidebar-target="label"><%= User.model_name.human %></span>
    <% end %>
  </nav>

  <% if user_signed_in? %>
    <div class="px-3 py-4 border-t border-slate-200">
      <div data-sidebar-target="link" class="flex items-center gap-3 px-3 py-2 mb-1">
        <div class="h-8 w-8 shrink-0 rounded-full bg-slate-200 flex items-center justify-center text-xs font-semibold text-slate-600">
          <%= current_user.email.first.upcase %>
        </div>
        <p data-sidebar-target="label" class="text-xs font-medium text-slate-900 truncate"><%= current_user.email %></p>
      </div>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete, "sidebar-target": "link" },
          class: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 w-full" do %>
        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        <span data-sidebar-target="label"><%= t('.sign_out') %></span>
      <% end %>
    </div>
  <% end %>
</aside>
