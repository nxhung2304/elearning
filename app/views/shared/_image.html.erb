<div data-controller="image-preview" class="image-upload-group">
  <%= f.label image, class: "block text-sm font-medium text-slate-700 mb-2" %>

  <label class="cursor-pointer inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-slate-300 text-sm text-slate-700 hover:bg-slate-50">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4-4m0 0l4 4m-4-4v12M20 16l-4-4m0 0l-4 4m4-4V4" />
    </svg>
    <%= t('helpers.image.select') %>
    <%= f.file_field image,
          accept: "image/*",
          class: "hidden",
          data: {
            image_preview_target: "input",
            action: "change->image-preview#update"
          } %>
  </label>

  <% attachment = resource.send(image) %>
  <span data-image-preview-target="filename" class="ml-2 text-sm text-slate-500 italic">
    <%= attachment.attached? ? attachment.filename : t("helpers.image.no_file_chosen") %>
  </span>

  <div class="mt-3">
    <% if attachment.attached? %>
      <%= image_tag attachment, data: { image_preview_target: "preview" }, class: "w-64 h-64 object-cover" %>
    <% else %>
      <img data-image-preview-target="preview" class="w-64 h-64 object-cover hidden" src="" alt="">
    <% end %>
  </div>
</div>
