<% add_breadcrumb @course.title, course_path(@course) %>
<% add_breadcrumb @section.title, course_section_path(@course, @section) %>
<% add_breadcrumb @lesson.title, course_section_lesson_path(@course, @section, @lesson) %>
<% add_breadcrumb t("helpers.links.edit") %>

<section class="mx-auto max-w-2xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">
      <%= t("helpers.submit.update", model: Lesson.model_name.human, default: "Edit Lesson") %>
    </h1>
    <%= link_to t("helpers.links.back", default: "Back"),
          course_section_lesson_path(@course, @section, @lesson),
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>

  <%= render "form", lesson: @lesson %>
</section>
