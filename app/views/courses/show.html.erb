<% add_breadcrumb "Courses", courses_path %>
<% add_breadcrumb @course.title %>
<section class="mx-auto max-w-3xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900"><%= Course.model_name.human %></h1>
    <%= link_to t("helpers.links.back", default: "Back"),
          courses_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
    <%= publish_toggle_link(@course) %>
    <% if @course.published? %>
      <%= link_to "Archive", archive_course_path, class: "text-sm text-slate-500 hover:text-slate-900", data: { turbo_method: :patch } %>
    <% end %>
  </div>
  <dl class="divide-y divide-slate-200 rounded-xl border border-slate-200">
    <% @course.class.visible_columns.each do |col| %>
      <div class="flex px-4 py-3 gap-4">
        <dt class="w-1/3 font-medium text-slate-600"><%= Course.human_attribute_name(col) %></dt>
        <dd class="text-slate-900"><%= @course.public_send(col) %></dd>
      </div>
    <% end %>
    <% @course.class.timestamp_columns.each do |col| %>
      <div class="flex px-4 py-3 gap-4">
        <dt class="w-1/3 font-medium text-slate-600"><%= Course.human_attribute_name(col) %></dt>
        <dd class="text-slate-500 text-sm"><%= @course.public_send(col)&.strftime("%Y-%m-%d %H:%M") %></dd>
      </div>
    <% end %>
  </dl>
  <div class="mt-6 overflow-hidden rounded-xl border border-slate-200">
    <div class="flex items-center justify-between bg-slate-50 px-4 py-3 border-b border-slate-200">
      <h2 class="font-semibold text-slate-700 text-sm"><%= Section.model_name.human(count: 2) %></h2>
      <%= link_to t("helpers.links.new", model: Section.model_name.human, default: "New Section"),
            new_course_section_path(@course),
            class: "rounded-md bg-emerald-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-emerald-700" %>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left font-bold text-slate-600"><%= Section.human_attribute_name(:title) %></th>
          <th class="px-4 py-3 text-left font-bold text-slate-600"><%= Section.human_attribute_name(:position) %></th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @course.sections.kept.each do |section| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= section.title %></td>
            <td class="px-4 py-3 text-slate-500"><%= section.position %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to t("helpers.links.show", default: "Show"),
                    course_section_path(@course, section),
                    class: "rounded-md border border-slate-300 px-4 py-1.5 text-xs font-medium text-slate-600 hover:border-slate-900 hover:text-slate-900 mr-2" %>
              <% if can?(:update, section) %>
                <%= link_to t("helpers.links.edit", default: "Edit"),
                      edit_course_section_path(@course, section),
                      class: "rounded-md border border-slate-300 px-4 py-1.5 text-xs font-medium text-slate-600 hover:border-slate-900 hover:text-slate-900 mr-2" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
