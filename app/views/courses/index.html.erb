<% add_breadcrumb t('.title') %>

<section class="mx-auto max-w-6xl px-6 py-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">
      <%= Course.model_name.human %>
    </h1>
    <%= link_to t("helpers.links.new", model: Course.model_name.human, default: "New Course"),
          new_course_path,
          class: "rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700" %>
  </div>

  <%= search_form_for @q, url: courses_path, html: { class: "mb-6" } do |f| %>
    <div class="flex gap-2">
      <%= f.select :teacher_id_eq,
            @teacher_collection,
            { include_blank: Course.human_attribute_name(:teacher), selected: @q.teacher_id_eq },
            class: "search-field" %>
      <%= f.select :category_id_eq,
            @category_collection,
            { include_blank: Course.human_attribute_name(:category), selected: @q.category_id_eq },
            class: "search-field" %>
      <%= f.search_field :title_cont,
            placeholder: Course.human_attribute_name(:title),
            class: "search-field" %>
      <%= f.select :status_eq,
            Course.statuses.map { |s, v| [Course.human_attribute_name("status.#{s}"), v] },
            { include_blank: Course.human_attribute_name(:status), selected: @q.status_eq },
            class: "search-field" %>
      <%= f.submit t("helpers.search.submit", default: "Search"),
            class: "cursor-pointer rounded-lg bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-200" %>
    </div>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-slate-200">
    <table class="w-full text-sm">
      <thead class="bg-slate-50">
        <tr>
          <% Course.index_columns.each do |col| %>
            <th class="px-4 py-3 text-left font-bold text-slate-600"><%= Course.human_attribute_name(col) %></th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% @courses.each do |course| %>
          <tr class="hover:bg-slate-50">
            <% display_course_columns(course) %>
            <td class="px-4 py-3 text-right">
              <%= link_to t("helpers.links.show", default: "Show"),
                    course_path(course),
                    class: "rounded-md border border-slate-300 px-4 py-1.5 text-xs font-medium text-slate-600 hover:border-slate-900 hover:text-slate-900 mr-2" %>
              <% if can?(:update, course) %>
                <%= link_to t("helpers.links.edit", default: "Edit"),
                      edit_course_path(course),
                      class: "rounded-md border border-slate-300 px-4 py-1.5 text-xs font-medium text-slate-600 hover:border-slate-900 hover:text-slate-900 mr-2" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4 flex justify-center">
    <%= pagy_nav(@pagy) if @pagy.pages > 1 %>
  </div>
</section>
