<%= simple_form_for course, html: { autocomplete: "off" } do |f| %>
  <% course.class.form_columns.each do |col| %>
    <% if col.end_with?("_id") && (reflection = course.class.reflect_on_association(col.delete_suffix("_id").to_sym)) %>
      <%= f.input col.to_sym, as: :select,
            collection: reflection.klass.kept.map { |r| [r.to_s, r.id] },
            include_blank: false,
            input_html: { class: "bg-white text-slate-900" } %>
    <% elsif course.class.defined_enums.key?(col) %>
      <%= f.input col.to_sym, as: :select, collection: course.class.defined_enums[col].keys, include_blank: false, wrapper: :select,
            input_html: { class: "bg-white text-slate-900" } %>
    <% else %>
      <%= f.input col.to_sym %>
    <% end %>
  <% end %>

  <div class="mt-6 flex items-center gap-3">
    <%= f.button :submit,
          t("helpers.submit.#{course.persisted? ? :update : :create}", model: Course.model_name.human),
          class: "rounded-lg #{course.persisted? ? "bg-slate-900 hover:bg-slate-700" : "bg-emerald-600 hover:bg-emerald-700"} px-4 py-2 text-sm font-medium text-white" %>
    <%= link_to t("helpers.links.cancel", default: "Cancel"),
          courses_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
