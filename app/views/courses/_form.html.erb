<%= simple_form_for course, html: { autocomplete: "off" } do |f| %>
  <%= f.input :title %>
  <%= f.input :description %>
  <%= f.input :price %>
  <%= f.input :total_lessons %>
  <%= f.input :level, as: :select, collection: Course.levels.keys, include_blank: false, wrapper: :select,
        input_html: { class: "bg-white text-slate-900" } %>
  <%= f.input :language, as: :select, collection: Course.languages.keys, include_blank: false, wrapper: :select,
        input_html: { class: "bg-white text-slate-900" } %>
  <%= f.input :status, as: :select, collection: Course.statuses.keys, include_blank: false, wrapper: :select,
        input_html: { class: "bg-white text-slate-900" } %>
  <%= f.input :category_id, as: :select,
        collection: CourseCategory.kept.map { |c| [c.name, c.id] },
        include_blank: false,
        input_html: { class: "bg-white text-slate-900" } %>

  <div class="mt-6 flex items-center gap-3">
    <%= f.button :submit,
          t("helpers.submit.#{course.persisted? ? :update : :create}", model: Course.model_name.human),
          class: "rounded-lg #{course.persisted? ? "bg-slate-900 hover:bg-slate-700" : "bg-emerald-600 hover:bg-emerald-700"} px-4 py-2 text-sm font-medium text-white" %>
    <%= link_to t("helpers.links.cancel", default: "Cancel"),
          courses_path,
          class: "text-sm text-slate-500 hover:text-slate-900" %>
  </div>
<% end %>
